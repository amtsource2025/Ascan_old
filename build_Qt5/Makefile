	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_viewpatientdialog.o moc_viewpatientdialog.cpp

moc_welcomedialog.o: moc_welcomedialog.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_welcomedialog.o moc_welcomedialog.cpp

moc_qcustomplot.o: moc_qcustomplot.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_qcustomplot.o moc_qcustomplot.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/Ascan.V1/bin || mkdir -p $(INSTALL_ROOT)/opt/Ascan.V1/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/Ascan.V1/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/Ascan.V1/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/Ascan.V1/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

